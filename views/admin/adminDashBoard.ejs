<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
    }
    .sidebar {
      min-height: 100vh;
      background-color: #212529;
    }
    .sidebar a {
      color: white;
      display: block;
      padding: 10px 15px;
      text-decoration: none;
    }
    .sidebar a:hover {
      background-color: #343a40;
    }
  </style>
</head>
<body>

<!-- <div class="container-fluid"> -->
  <!-- <div class="row"> -->

    <!-- Sidebar -->
    <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse">
      <div class="position-sticky">
        <a href="#">Dashboard</a>
        <a href="#">Orders</a>
        <a href="#">Products</a>
        <a href="#">Customers</a>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="">

      <!-- Header -->
      <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4">
        <div>
          <h1 class="h2 fw-bold text-dark">Dashboard</h1>
          <p class="text-muted mb-0">Welcome back, John! Here's what's happening with your store.</p>
        </div>
        <button class="btn btn-primary d-flex align-items-center mt-3 mt-sm-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" class="me-2" viewBox="0 0 24 24"><path d="M12 6v12M6 12h12"/></svg>
          Add New
        </button>
      </div>

      <!-- Stats Cards -->
      <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-lg-3">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center">
              <div class="bg-primary bg-opacity-10 p-3 rounded">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
              </div>
              <div class="ms-3">
                <p class="text-muted mb-1">Total Orders</p>
                <h4 class="fw-bold mb-0">1,234</h4>
                <small class="text-success">↑ 12% from last month</small>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center">
              <div class="bg-success bg-opacity-10 p-3 rounded">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/></svg>
              </div>
              <div class="ms-3">
                <p class="text-muted mb-1">Revenue</p>
                <h4 class="fw-bold mb-0">$45,678</h4>
                <small class="text-success">↑ 8% from last month</small>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center">
              <div class="bg-purple bg-opacity-10 p-3 rounded" style="background-color: #f3e8ff;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
              </div>
              <div class="ms-3">
                <p class="text-muted mb-1">Customers</p>
                <h4 class="fw-bold mb-0">892</h4>
                <small class="text-success">↑ 5% from last month</small>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center">
              <div class="bg-warning bg-opacity-10 p-3 rounded">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              </div>
              <div class="ms-3">
                <p class="text-muted mb-1">Products</p>
                <h4 class="fw-bold mb-0">156</h4>
                <small class="text-danger">↓ 2% from last month</small>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Orders -->
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom">
          <h5 class="mb-0">Recent Orders</h5>
        </div>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Product</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>#ORD-001</td>
                <td>John Doe</td>
                <td>Premium T-Shirt</td>
                <td>$29.99</td>
                <td><span class="badge bg-success">Completed</span></td>
                <td>2025-01-15</td>
                <td><button class="btn btn-sm btn-link text-primary">View</button></td>
              </tr>
              <tr>
                <td>#ORD-002</td>
                <td>Jane Smith</td>
                <td>Designer Jeans</td>
                <td>$79.99</td>
                <td><span class="badge bg-warning text-dark">Pending</span></td>
                <td>2025-01-15</td>
                <td><button class="btn btn-sm btn-link text-primary">View</button></td>
              </tr>
              <tr>
                <td>#ORD-003</td>
                <td>Mike Johnson</td>
                <td>Sports Shoes</td>
                <td>$129.99</td>
                <td><span class="badge bg-info text-dark">Processing</span></td>
                <td>2025-01-14</td>
                <td><button class="btn btn-sm btn-link text-primary">View</button></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  <!-- </div> -->
<!-- </div> -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
