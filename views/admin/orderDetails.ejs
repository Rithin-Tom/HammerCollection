<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Details</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container my-5">
  <div class="card shadow rounded">
    <div class="card-header bg-dark text-white">
      <h4 class="mb-0">Order Details</h4>
    </div>
    <div class="card-body">

      <!-- Order Info -->
      <h5>Order ID: <span class="text-muted">#<%=order.orderId%></span></h5>
      <p><strong>Order Date: <%= order.createdOn.toLocaleDateString('en-US', {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        year: 'numeric'
      }).replace(/,/g, '') %></strong></p>
      <p><strong>Status:</strong> <span class="badge bg-success"><%=order.orderStatus%></span></p>

      <hr>

      <!-- Customer Info -->
      <h5>Customer Information</h5>
      <p><strong>Name:</strong><%=order.userId.name%></p>
      <p><strong>Email:</strong><%=order.userId.email%></p>
      <p><strong>Phone:</strong><%=order.userId.phone%></p>

      <hr>

      <!-- Shipping Address -->
      <h5>Shipping Address</h5>
      <p>
        <%=order.address.addressType%>,<br>
        <%=order.address.city%>,<%=order.address.state%> - <%=order.address.pincode%><br>
       <%=order.address.addressLine%><br>
        <%=order.address.phone%>
      </p>

      <hr>

      <!-- Ordered Items -->
      <h5>Ordered Items</h5>
      <table class="table table-bordered align-middle">
        <thead class="table-light">
          <tr>
            <th>Image</th>
            <th>Product</th>
            <th>Qty</th>
            
            <th></th>
            <th>Price</th>
          </tr>
        </thead>

        <% order.orderedItems.forEach(element => { %>
         <tbody>
          <tr>
            <td>
              <img src="/<%= element.productId.productImage[0] %>" alt="Marvel T-Shirt" style="width: 80px; height: 80px; object-fit: cover;"  class="img-thumbnail">
            </td>
            <td><%= element.productId.productName%></td>
            <td><%= element.quantity%></td>
            
            <td></td>
            <td>₹<%= element.price%></td>
          </tr>
        </tbody>
        <% }) %>
        
        <tfoot>
          <tr>
            <th colspan="4" class="text-end">Total</th>
            <th>₹<%=order.totalAmount%></th>
          </tr>
        </tfoot>
      </table>

      <hr>

      <!-- Payment Info -->
      <h5>Payment Information</h5>
      <p><strong>Payment Method:</strong><%=order.paymentMethod%></p>
      <p><strong>Transaction ID:</strong> TXN123456789</p>

      <div class="mt-4">
        <a href="/admin/orders" class="btn btn-secondary">Back to Orders</a>
        <!-- <button class="btn btn-danger">Cancel Order</button> -->
      </div>

    </div>
  </div>
</div>

</body>
</html>
