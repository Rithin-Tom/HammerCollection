<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Alpine.js -->
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: {
              600: "#2563eb",
              700: "#1d4ed8",
            },
          },
          fontFamily: {
            sans: ["Inter", "system-ui", "sans-serif"],
          },
        },
      },
    };
  </script>

  <style>
    body {
      margin: 0;
      padding: 0;
    }
    main {
      padding-top: 64px; /* space for fixed navbar */
    }
  </style>
</head>
<body class="bg-gray-50 font-sans">

  <!-- Header -->
  <nav class="fixed top-0 left-0 right-0 bg-gradient-to-r from-primary-600 to-primary-700 shadow-md z-50"
       x-data="{ mobileMenuOpen: false, profileOpen: false }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        
        <!-- Left: Logo & Search -->
        <div class="flex items-center space-x-6">
          <a href="#" class="flex items-center text-white font-bold text-xl">
            <svg class="w-8 h-8 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd"
                    d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
            </svg>
            Admin Panel
          </a>

          <!-- Desktop Search -->
          <div class="hidden md:block">
            <div class="relative">
              <input type="text"
                     placeholder="Search..."
                     class="w-72 pl-10 pr-3 py-2 rounded-lg bg-white/10 text-white placeholder-white/70
                            focus:outline-none focus:ring-2 focus:ring-white/50">
              <svg class="absolute left-3 top-2.5 w-5 h-5 text-white/70" fill="none"
                   stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- Right: Profile -->
        <div class="flex items-center space-x-4">
          <!-- Mobile Menu Button -->
          <button @click="mobileMenuOpen = !mobileMenuOpen"
                  class="md:hidden text-white focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>

          <!-- Profile Dropdown -->
          <div class="relative" x-data="{ open: false }">
            <button @click="open = !open"
                    class="flex items-center text-white space-x-2 focus:outline-none">
              <img src="/images/admin-avatar.jpg" alt="Avatar"
                   class="w-10 h-10 rounded-full border-2 border-white/30">
              <span class="hidden sm:block font-medium">John Admin</span>
              <svg :class="{ 'rotate-180': open }" class="w-4 h-4 transition-transform"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <!-- Dropdown -->
            <div x-show="open" @click.away="open = false"
                 class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg ring-1 ring-black/5">
              <a href="/admin/profile"
                 class="block px-4 py-2 text-gray-700 hover:bg-gray-100">Profile</a>
              <a href="/admin/logout"
                 class="block px-4 py-2 text-red-600 hover:bg-red-50">Logout</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Search -->
    <div x-show="mobileMenuOpen" class="md:hidden border-t border-white/20 px-4 py-3">
      <input type="text"
             placeholder="Search..."
             class="w-full px-3 py-2 rounded-lg bg-white/10 text-white placeholder-white/70
                    focus:outline-none focus:ring-2 focus:ring-white/50">
    </div>
  </nav>

  <!-- MAIN CONTENT (Example) -->
  <!-- <main class="p-6">
    <h1 class="text-2xl font-bold">Dashboard Content</h1>
    <p class="mt-4">Your content goes here...</p>
  </main> -->

</body>
</html>
