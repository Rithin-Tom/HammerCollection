<!-- Bootstrap 5 CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Cropper.js CSS -->

<link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet" />

<!-- Cropper.js JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<body style="
  margin: 0;
  padding: 0;
  font-family: Arial, sans-serif;
  background-image: url('https://i.pinimg.com/736x/fa/4a/fa/fa4afaac480367b0867308624a84fda9.jpg'); /* Replace with your actual image path */
  background-size: cover;
  background-position: center;
  min-height: 100vh;
">

  <div class="container-fluid">
    <div class="row">

      <!-- Sidebar -->

      <%- include('../partials/user/sideBar', { user: user }) %>

      <!-- Main Content -->
      <div class="col-12 col-md-9 d-flex justify-content-center align-items-center p-4">
        <div class="bg-white rounded-4 shadow p-4" style="width: 100%; border: 40px solid  rgb(27 57 84);;  max-width: 700px;">

          <div class="text-center position-relative mb-4">
            <% if (user) { %>
       <!-- Profile Image with Edit Button -->
<div class="mx-auto position-relative" style="width: 140px; height: 140px;">
  <div style="width: 140px; height: 140px; border-radius: 50%; overflow: hidden;">
    <img id="profileImage" src="<%= user.profileImage %>" alt="Profile Image"
         style="width: 100%; height: 100%; object-fit: cover;">
  </div>

  <button class="btn btn-sm btn-primary position-absolute" 
          style="top: -10px; right: -10px; border-radius: 50%; padding: 5px 8px;"
          data-bs-toggle="modal" 
          data-bs-target="#imageCropModal"
          title="Edit Profile Image">
    <i class="bi bi-pencil-square"></i>
  </button>
</div>

<!-- Bootstrap Modal for Cropping -->
<div class="modal fade" id="imageCropModal" tabindex="-1" aria-labelledby="imageCropModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit Profile Image</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body text-center">
        <input type="file" id="inputImage"  name="profileImage" accept="image/*" class="form-control mb-3">

        <!-- Image for cropping -->
        <div>
          <img id="imagePreview" style="max-width: 100%; max-height: 400px;">
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-success" id="cropAndUploadBtn">Crop & Upload</button>
      </div>
    </div>
  </div>
</div>
            

            <% } else { %>
            <i class="bi bi-person-circle" style="font-size: 100px; color: #333;"></i>
            <% } %>

            <a href='/profile/edit' ; class="btn btn-sm btn-outline-secondary position-absolute end-0 top-0">

              <i class="bi bi-pencil-square"></i> Edit Profile
            </a>
            <h4 class="mt-2 mb-3"><%=user.name.toUpperCase() %></h4>
            <div class="d-flex justify-content-between flex-wrap gap-3 mb-4">
              <div class="flex-fill text-center bg-light rounded-3 p-3" style="min-width: 120px;">
                  <a  href="/cart" class="d-inline-block text-dark text-decoration-none"> 
                <i class="bi bi-box-seam" style="font-size: 30px;"></i>
                <div class="mt-2 fw-semibold">Orders</div>
                </a>
              </div>

              <div class="flex-fill text-center bg-light rounded-3 p-3" style="min-width: 120px;">
                <a  href="/cart" class="d-inline-block text-dark text-decoration-none"> 
                <i class="bi bi-heart" style="font-size: 30px;"></i>
                <div class="mt-2 fw-semibold">Wishlist</div>
                </a>
              </div>
                 
              <div class="flex-fill text-center bg-light rounded-3 p-3" style="min-width: 120px;">
                <a  href="/cart" class="d-inline-block text-dark text-decoration-none"> 
                <i  class="bi bi-cart" style="font-size: 30px;"></i>
                <div class="mt-2 fw-semibold">Cart</div>
                </a>
              </div>
              

              <div class="flex-fill text-center bg-light rounded-3 p-3" style="min-width: 120px;">
                  <a  href="/cart" class="d-inline-block text-dark text-decoration-none"> 
                <i class="bi bi-people" style="font-size: 30px;"></i>
                <div class="mt-2 fw-semibold">Referred Users</div>
                 </a>
              </div>
            </div>


            <div class="p-3 rounded-3" style="background-color: #1b3954; color: white;">
              <p><strong>Full Name:</strong><%=user.name ? user.name :"" %></p>
              <p><strong>Email:</strong> <%=user.email%></p>
              <% if(user.phone) { %>
              <p><strong>Phone No:</strong> <%= user.phone %></p>
              <% } else { %>
              <p> </p>
              <% } %>
            

              <p><strong>Referral Code:</strong><%=user?.ref%></p>
            </div>

          </div>
        </div>


      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>



</body>
<script>
  let cropper;
  const input = document.getElementById('inputImage');
  const image = document.getElementById('imagePreview');
  const profileImage = document.getElementById('profileImage');
  const modalEl = document.getElementById('imageCropModal');
  let bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);
  const uploadBtn = document.getElementById('cropAndUploadBtn');

  input.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;

    if (cropper) cropper.destroy();

    const url = URL.createObjectURL(file);
    image.src = url;

   
    


    image.onload = () => {
      cropper = new Cropper(image, {
        aspectRatio: 1,
        viewMode: 1,
        dragMode: 'move',
        preview: '.preview',
        autoCropArea: 1
      });
    };
  });

  
  document.getElementById('cropAndUploadBtn').addEventListener('click', async () => {
    if (!cropper) return Swal.fire({
              title: 'error!',
              text: 'Please upload an image first.',
              icon: 'error',
              confirmButtonText: 'OK'
            });

    const canvas = cropper.getCroppedCanvas({
      width: 300,
      height: 300
    });

    Swal.fire({
  title: 'Uploading...',
  text: 'Please wait while we upload your image.',
  allowOutsideClick: false,
  didOpen: () => {
    Swal.showLoading();
  }
});

uploadBtn.disabled = true;

    canvas.toBlob(async (blob) => {
      const formData = new FormData();
      formData.append('profileImage', blob);
      const res = await fetch('/profile/uploadimage', {
        method: 'POST',
        body: formData
      });

      const data = await res.json();

      if (data.success) {
        //  Swal.fire({
        //       title: 'Success!',
        //       text: 'Your profile image was updated.',
        //       icon: 'success',
        //       confirmButtonText: 'OK'
        //     });
            profileImage.src = data.imageUrl + '?t=' + new Date().getTime();
             bsModal.hide();
             window.location.reload()
             uploadBtn.disabled = false;
       
        
      } else {
        uploadBtn.disabled = false;
         Swal.fire({
            title: 'Upload Failed!',
            text: data.message || 'Something went wrong.',
            icon: 'error',
            confirmButtonText: 'OK'
          });
      }
    }, 'image/jpeg');
  });
</script>
  