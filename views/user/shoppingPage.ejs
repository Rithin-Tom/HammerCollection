<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Premium Shop - Modern Grid</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #2966c4;
            --secondary-blue: #3b82f6;
            --bg-gradient: linear-gradient(-45deg, #e0eafc, #cfdef3, #eef2f3);
            --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-gradient);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            color: #334155;
            min-height: 100vh;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Sidebar Styling */
        .sidebar-card {
            border: none;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            box-shadow: var(--card-shadow);
            position: sticky;
            top: 24px;
        }

        .filter-section-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            color: #64748b;
            margin-bottom: 1.25rem;
        }

        .category-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            margin-bottom: 0.75rem;
            transition: var(--transition);
        }

        .category-card:hover { border-color: var(--primary-blue); }

        .main-category {
            padding: 12px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
        }

        .tag {
            font-size: 0.85rem;
            padding: 6px 14px;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
            background: white;
            color: #475569;
            cursor: pointer;
            transition: var(--transition);
            display: inline-block;
            margin: 4px;
        }

        .tag.selected {
            background: var(--primary-blue);
            color: white;
            border-color: var(--primary-blue);
            transform: translateY(-1px);
        }

        /* Product Card Styling */
        .product-card {
            border: none;
            border-radius: 20px;
            background: #fff;
            transition: var(--transition);
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .img-container {
            position: relative;
            aspect-ratio: 1/1;
            background: #f8fafc;
            overflow: hidden;
        }

        .img-container img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 20px;
            transition: transform 0.6s ease;
        }

        .product-card:hover img { transform: scale(1.1); }

        .wishlist-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            z-index: 10;
            background: white;
            border: none;
            border-radius: 50%;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            transition: var(--transition);
        }

        .discount-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            background: #ef4444;
            color: white;
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 6px;
        }

        .card-body { padding: 1.5rem; flex-grow: 1; }

        .product-title {
            font-size: 1rem;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 0.5rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            height: 2.4rem;
        }

        .price-container { display: flex; align-items: baseline; gap: 8px; }
        .current-price { font-size: 1.25rem; font-weight: 700; color: var(--primary-blue); }
        .old-price { font-size: 0.9rem; color: #94a3b8; text-decoration: line-through; }

        .add-to-cart-btn {
            width: 100%;
            border-radius: 12px;
            padding: 10px;
            font-weight: 600;
            transition: var(--transition);
            background: #1e293b;
            color: white;
            border: none;
        }

        .add-to-cart-btn:hover { background: var(--secondary-blue); transform: translateY(-2px); }
        .add-to-cart-btn:disabled { opacity: 0.7; cursor: not-allowed; }

        .star-rating { color: #fbbf24; font-size: 0.85rem; }
    </style>
</head>

<body>
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-lg-3">
                <div class="card sidebar-card p-4">
                    <h3 class="fw-bold mb-4" style="color: #1e293b;">Filters</h3>

                    <div class="mb-4">
                        <p class="filter-section-title">Categories</p>
                        <div id="categoryFilters">
                            <% categories.forEach(main => { %>
                            <div class="category-card">
                                <div class="main-category" onclick="toggleCategory(this)">
                                    <span class="fw-medium text-dark"><%= main.name %></span>
                                    <span class="text-muted small" style="transition: 0.3s">▼</span>
                                </div>
                                <div class="subcategory-list p-2" style="display: none;">
                                    <span class="tag" data-id="<%= main._id %>" onclick="toggleTag(this)">All <%= main.name %></span>
                                    <% main.children.forEach(sub => { %>
                                    <span class="tag" data-id="<%= sub._id %>" onclick="toggleTag(this)"><%= sub.name %></span>
                                    <% }) %>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="mb-4">
                        <p class="filter-section-title">Price Range</p>
                        <div class="d-flex gap-2">
                            <input type="number" id="minPrice" placeholder="Min" class="form-control form-control-sm border-0 bg-light">
                            <input type="number" id="maxPrice" placeholder="Max" class="form-control form-control-sm border-0 bg-light">
                        </div>
                    </div>

                    <div class="mb-4">
                        <p class="filter-section-title">Min Rating</p>
                        <div class="d-flex flex-column gap-2">
                            <div class="form-check custom-checkbox">
                                <input class="form-check-input" type="radio" name="ratingFilter" id="rating4" value="4">
                                <label class="form-check-label small" for="rating4">4★ & Above</label>
                            </div>
                            <div class="form-check custom-checkbox">
                                <input class="form-check-input" type="radio" name="ratingFilter" id="rating3" value="3">
                                <label class="form-check-label small" for="rating3">3★ & Above</label>
                            </div>
                            <div class="form-check custom-checkbox">
                                <input class="form-check-input" type="radio" name="ratingFilter" id="ratingAll" value="" checked>
                                <label class="form-check-label small" for="ratingAll">All Ratings</label>
                            </div>
                        </div>
                    </div>

                    <button onclick="applyFilters(1)" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 12px; background: var(--primary-blue); border:none;">
                        Apply Filters
                    </button>
                    <button onclick="resetFilters()" class="btn btn-link w-100 btn-sm mt-2 text-muted text-decoration-none">Clear All</button>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="row g-3 mb-4 align-items-center">
                    <div class="col-md-6">
                       
                    </div>
                    <div class="col-md-6 d-flex justify-content-md-end align-items-center gap-3">
                        <p id="paginationInfo" class="text-muted mb-0 small fw-medium">Loading...</p>
                        <select id="sortOrder" onchange="applyFilters(1)" class="form-select border-0 bg-white shadow-sm" style="width: auto; border-radius: 10px; font-size: 0.9rem;">
                            <option value="featured">Featured</option>
                            <option value="lowToHigh">Price: Low to High</option>
                            <option value="highToLow">Price: High to Low</option>
                        </select>
                    </div>
                </div>

                <div id="productGrid" class="row g-4" style="transition: opacity 0.3s ease;">
                    </div>

                <nav class="mt-5">
                    <ul class="pagination justify-content-center" id="pagination"></ul>
                </nav>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const selectedFilters = new Set();
        let currentPage = 1;

        function toggleCategory(header) {
            const list = header.nextElementSibling;
            const arrow = header.querySelector('.text-muted');
            const isVisible = list.style.display === "block";
            list.style.display = isVisible ? "none" : "block";
            arrow.style.transform = isVisible ? "rotate(0deg)" : "rotate(180deg)";
        }

        function toggleTag(tag) {
            tag.classList.toggle("selected");
            const id = tag.dataset.id;
            tag.classList.contains("selected") ? selectedFilters.add(id) : selectedFilters.delete(id);
        }

        function resetFilters() {
            selectedFilters.clear();
            document.querySelectorAll('.tag').forEach(t => t.classList.remove('selected'));
            document.getElementById('minPrice').value = '';
            document.getElementById('maxPrice').value = '';
            document.getElementById('ratingAll').checked = true;
            document.getElementById('headerSearch').value = '';
            applyFilters(1);
        }

        function renderProducts(products) {
            const grid = document.getElementById("productGrid");
            grid.innerHTML = "";

            if (!products.length) {
                grid.innerHTML = `
                <div class="col-12 text-center py-5">
                    <img src="https://cdn-icons-png.flaticon.com/512/6134/6134065.png" width="80" class="mb-3 opacity-25">
                    <p class="text-muted">No products match your criteria.</p>
                </div>`;
                return;
            }

            products.forEach(p => {
                const discount = p.regularPrice > p.salePrice ? Math.round(((p.regularPrice - p.salePrice) / p.regularPrice) * 100) : 0;
                const stars = "★".repeat(p.rating || 0) + "☆".repeat(5 - (p.rating || 0));

                grid.innerHTML += `
                <div class="col-sm-6 col-md-4 col-xl-4">
                    <div class="product-card">
                        <div class="img-container">
                            ${discount > 0 ? `<div class="discount-badge">-${discount}%</div>` : ''}
                            <button onclick="addToWishlist('${p._id}')" class="wishlist-btn" data-id="${p._id}">
                                <svg width="20" height="20" fill="${p.isWishlist ? '#ef4444' : '#cbd5e1'}" viewBox="0 0 24 24">
                                    <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.5 3c1.557 0 3.046.727 4 2.015Q12.454 3 14.5 3c2.786 0 5.25 2.322 5.25 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
                                </svg>
                            </button>
                            <a href="/product/${p._id}">
                                <img src="${p.productImage[0]}" alt="${p.productName}">
                            </a>
                        </div>
                        <div class="card-body">
                            <div class="star-rating mb-1">${stars}</div>
                            <h5 class="product-title">${p.productName}</h5>
                            <div class="price-container mb-3">
                                <span class="current-price">₹${p.salePrice.toLocaleString()}</span>
                                ${p.regularPrice > p.salePrice ? `<span class="old-price">₹${p.regularPrice.toLocaleString()}</span>` : ''}
                            </div>
                            <button onclick="addToCart('${p._id}', ${p.salePrice}, this)" class="add-to-cart-btn">
                                Add to Cart
                            </button>
                        </div>
                    </div>
                </div>`;
            });
        }

        function updatePagination(total, current, totalPages) {
            const pagination = document.getElementById("pagination");
            const info = document.getElementById("paginationInfo");

            const start = total === 0 ? 0 : (current - 1) * 8 + 1;
            const end = Math.min(current * 8, total);
            info.textContent = `Showing ${start}–${end} of ${total} items`;

            pagination.innerHTML = "";
            if (totalPages <= 1) return;

            const prevLi = document.createElement("li");
            prevLi.className = `page-item ${current === 1 ? 'disabled' : ''}`;
            prevLi.innerHTML = `<a class="page-link" href="#">Prev</a>`;
            prevLi.onclick = (e) => { e.preventDefault(); if(current > 1) applyFilters(current - 1); };
            pagination.appendChild(prevLi);

            for (let i = 1; i <= totalPages; i++) {
                const li = document.createElement("li");
                li.className = `page-item ${i === current ? 'active' : ''}`;
                li.innerHTML = `<a class="page-link" href="#">${i}</a>`;
                li.onclick = (e) => { e.preventDefault(); applyFilters(i); };
                pagination.appendChild(li);
            }

            const nextLi = document.createElement("li");
            nextLi.className = `page-item ${current === totalPages ? 'disabled' : ''}`;
            nextLi.innerHTML = `<a class="page-link" href="#">Next</a>`;
            nextLi.onclick = (e) => { e.preventDefault(); if(current < totalPages) applyFilters(current + 1); };
            pagination.appendChild(nextLi);
        }

        async function applyFilters(page = 1) {
            currentPage = page;
            const grid = document.getElementById("productGrid");
            grid.style.opacity = "0.5";

            const filters = {
                page: currentPage,
                limit: 8,
                categoryIds: [...selectedFilters],
                minPrice: document.getElementById("minPrice").value || null,
                maxPrice: document.getElementById("maxPrice").value || null,
                rating: document.querySelector('input[name="ratingFilter"]:checked').value || null,
                search: document.getElementById("headerSearch").value.trim() || null,
                sort: document.getElementById("sortOrder").value
            };

            try {
                const res = await fetch("/filter-products", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(filters),
                });
                const data = await res.json();
                
                if (data.success) {
                    renderProducts(data.products);
                    updatePagination(data.totalProducts, data.currentPage, data.totalPages);
                }
            } catch (error) {
                console.error("Filter Error:", error);
            } finally {
                grid.style.opacity = "1";
            }
        }

        async function addToWishlist(id) {
            try {
                const res = await fetch('/wishList/add', {
                    method: "POST",
                    headers: { 'content-type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                const result = await res.json();
                
                if (result.success) {
                    const btn = document.querySelector(`.wishlist-btn[data-id="${id}"] svg`);
                    if (btn) btn.setAttribute("fill", result.isWishList ? "#ef4444" : "#cbd5e1");
                    
                    Swal.fire({
                        toast: true, position: "top-end", icon: "success",
                        title: result.message || "Updated Wishlist",
                        showConfirmButton: false, timer: 1500
                    });
                }
            } catch (error) {
                console.error("Wishlist Error:", error);
            }
        }

        async function addToCart(id, price, btn) {
            btn.disabled = true;
            try {
                const res = await fetch("/cart/add", {
                    method: "POST",
                    headers: { "content-type": "application/json" },
                    body: JSON.stringify({ id, price }),
                });
                const data = await res.json();

                Swal.fire({
                    toast: true, position: "top-end",
                    icon: data.success ? "success" : "error",
                    title: data.message || (data.success ? "Added to cart!" : "Failed"),
                    showConfirmButton: false, timer: 1500
                });
            } catch (error) {
                console.error("Cart Error:", error);
            } finally {
                btn.disabled = false;
            }
        }

        window.onload = () => applyFilters(1);
    </script>
</body>
</html>