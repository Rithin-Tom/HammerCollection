<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Details</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      background-image: url('https://i.pinimg.com/736x/fa/4a/fa/fa4afaac480367b0867308624a84fda9.jpg');
      background-size: cover;
      background-position: center;
      min-height: 100vh;
    }
    .order-detail-card {
      border: 1px solid #ddd;
      border-radius: 12px;
      padding: 20px;
      background: #fff;
    }
    .order-item img {
      width: 80px;
      height: 80px;
      object-fit: contain;
      border: 1px solid #ddd;
      border-radius: 8px;
    }
  </style>
</head>
<body>

<div class="container-fluid">
  <div class="row">

    <!-- Sidebar Placeholder -->
    <!-- <div class="col-12 col-md-3 p-3"> -->
      <!-- Example Sidebar -->
   <%- include('../partials/user/sideBar', { user: user }) %>
    <!-- </div> -->

    <!-- Main Content -->
    <div class="col-12 col-md-9 p-4">
      <div class="bg-white rounded-4 shadow p-4" style="border: 40px solid rgb(27 57 84); max-width: 900px; margin: auto;">
        
        <h3 class="text-center mb-4">Order Details</h3>

        <div class="order-detail-card mb-4">
          <div class="d-flex justify-content-between">
            <h6>Order ID:<%= orders.orderId %> </h6>
            <span class="badge bg-warning"><%= orders.orderStatus %></span>
          </div>
          <small class="text-muted">Placed on:<%= orders.createdOn.toLocaleDateString('en-US', {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        year: 'numeric'
      }).replace(/,/g, '') %></small>
        </div>

        <!-- Order Items -->
        <% orders.orderedItems.forEach(element => { %>
         <div class="order-item d-flex align-items-center mb-3">
          <img src="/<%= element.productId.productImage[0]%>" alt="Product">
          <div class="ms-3">
            <h6><%= element.productId.productName %></h6>
            <p class="mb-0 text-muted">Qty: <%= element.quantity %> | Price: ₹<%= element.price %></p>
          </div>
        </div>
        <hr>
        <% }) %>
        

      

        <!-- Total -->
        <h5 class="mt-3">Total Amount: ₹<%= orders.finalAmount %></h5>

        <!-- Actions -->
        <div class="mt-4 d-flex justify-content-between">
          <a href="/orders" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Orders</a>
         <% if (orders.orderStatus === "Cancelled") { %>
  <button class="btn btn-secondary" disabled>
    <i class="bi bi-x-circle"></i> Order  Cancelled
  </button>
  <% } else if (orders.orderStatus === "Delivered") { %>
  <button class="btn btn-warning" data-bs-toggle="modal" id="returnOrderBtn" data-bs-target="#returnModal">
    <i class="bi bi-box-arrow-in-left"></i> Return Product
  </button>
<% } else { %>
  <button class="btn btn-danger" data-bs-toggle="modal" id="orderStatusBadge" data-bs-target="#cancelModal">
    <i class="bi bi-x-circle"></i> Cancel Order
  </button>
<% } %>

        </div>

      </div>
    </div>

  </div>
</div>



<!-- Return Product Modal -->
<div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Return Product</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        <p>Are you sure you want to return this product?</p>

        <div class="mb-3">
          <label class="form-label">Select Reason</label>
          <select id="returnReason" class="form-select">
            <option value="">-- Select Reason --</option>
            <option value="Product defective">Product defective</option>
            <option value="Wrong item received">Wrong item received</option>
            <option value="Better price elsewhere">Better price elsewhere</option>
            <option value="Ordered by mistake">Ordered by mistake</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <!-- <div class="mb-3">
          <label class="form-label">Additional Details (Optional)</label>
          <textarea id="returnDetails" class="form-control" rows="3" placeholder="Provide additional details..."></textarea>
        </div> -->

        <!-- Hidden input to store order ID -->
        <input type="hidden" id="returnOrderId" value="<%= orders._id %>">
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button id="confirmReturnBtn" type="button" class="btn btn-warning">Confirm Return</button>
      </div>

    </div>
  </div>
</div>

<!-- Cancel Order Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      
      <div class="modal-header">
        <h5 class="modal-title">Cancel Order</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        <p>Are you sure you want to cancel this order?</p>

        <div class="mb-3">
          <label class="form-label">Select Reason </label>
          <select id="cancelReason" class="form-select">
            <option value="">-- Select Reason --</option>
            <option value="Ordered by mistake">Ordered by mistake</option>
            <option value="Found cheaper elsewhere">Found cheaper elsewhere</option>
            <option value="Shipping time too long">Shipping time too long</option>
            <option value="Need to change address">Need to change address</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <!-- <div class="mb-3">
          <label class="form-label">Additional Details (Optional)</label>
          <textarea id="cancelDetails" class="form-control" rows="3" placeholder="Provide additional details..."></textarea>
        </div> -->

        <input type="hidden" id="cancelOrderId" value="<%= orders._id %>">
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button id="confirmCancelBtn" type="button" class="btn btn-danger">Confirm Cancel</button>
      </div>
    </div>
  </div>
</div>


</body>
</html>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
  const confirmCancelBtn = document.getElementById("confirmCancelBtn");

  confirmCancelBtn.addEventListener("click", async () => {
    const orderId = document.getElementById("cancelOrderId").value;
    const reason = document.getElementById("cancelReason").value || "";

    Swal.fire({
      title: "Are you sure?",
      text: "Do you really want to cancel this order?",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#d33",
      cancelButtonColor: "#3085d6",
      confirmButtonText: "Yes, cancel it",
      cancelButtonText: "No, keep it"
    }).then(async (result) => {
      if (!result.isConfirmed) return;

      try {
        confirmCancelBtn.disabled = true;
        confirmCancelBtn.textContent = "Processing...";

        const res = await fetch(`/orders/cancel`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ reason,orderId })
        });

        const data = await res.json();

        if (res.ok && data.success) {
      
          const modalEl = document.getElementById("cancelModal");
          const modal = bootstrap.Modal.getInstance(modalEl);
          modal.hide();


         
          Swal.fire("Cancelled!", "Your order has been cancelled.", "success");
          window.location.href='/orders'
        } else {
          Swal.fire("Error!", data.message || "Failed to cancel order", "error");
        }
      } catch (err) {
        console.error(err);
        Swal.fire("Error!", "Server error while cancelling order", "error");
      } finally {
        confirmCancelBtn.disabled = false;
        confirmCancelBtn.textContent = "Confirm Cancel";
      }
    });
  });
});


// 

document.addEventListener("DOMContentLoaded", () => {
  const confirmReturnBtn = document.getElementById("confirmReturnBtn");

  confirmReturnBtn.addEventListener("click", async () => {
    const orderId = document.getElementById("returnOrderId").value;
    const reason = document.getElementById("returnReason").value || "";

    Swal.fire({
      title: "Are you sure?",
      text: "Do you really want to Return  this order?",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#d33",
      cancelButtonColor: "#3085d6",
      confirmButtonText: "Yes, return it",
      cancelButtonText: "No, keep it"
    }).then(async (result) => {
      if (!result.isConfirmed) return;

      try {
        confirmCancelBtn.disabled = true;
        confirmCancelBtn.textContent = "Processing...";

        const res = await fetch(`/orders/return`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ reason,orderId })
        });

        const data = await res.json();

        if (res.ok && data.success) {
      
          const modalEl = document.getElementById("returnModal");
          const modal = bootstrap.Modal.getInstance(modalEl);
          modal.hide();


         
          Swal.fire("Returned!", "Your order has been returned.", "success");
          window.location.href='/orders'
        } else {
          Swal.fire("Error!", data.message || "Failed to return order", "error");
        }
      } catch (err) {
        console.error(err);
        Swal.fire("Error!", "Server error while returning order", "error");
      } finally {
        confirmCancelBtn.disabled = false;
        confirmCancelBtn.textContent = "Confirm Cancel";
      }
    });
  });
});
</script>
